---
extends: default

ignore:
  - .venv/
  - .cache/
  - .superpowers/

rules:
  line-length:
    max: 120
    level: warning
  truthy:
    allowed-values: ["true", "false", "yes", "no"]
  comments:
    require-starting-space: true
    min-spaces-from-content: 1
  comments-indentation: false
  indentation:
    spaces: 2
    indent-sequences: true
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
